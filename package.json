{
  "name": "harness-kit",
  "version": "0.3.0",
  "description": "A stack-agnostic scaffolding kit for AI-coding-agent harnesses. Drops a complete 5-subsystem harness (instructions / state / feedback / observability / governance) into any new or existing repo. Based on walkinglabs/learn-harness-engineering.",
  "keywords": [
    "ai-agents",
    "agents-md",
    "harness-engineering",
    "claude-code",
    "codex",
    "opencode",
    "scaffolding",
    "developer-tools",
    "coding-agent"
  ],
  "homepage": "https://github.com/Bojun-Vvibe/harness-kit#readme",
  "bugs": "https://github.com/Bojun-Vvibe/harness-kit/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Bojun-Vvibe/harness-kit.git"
  },
  "license": "MIT",
  "author": "Bojun Chai (https://github.com/Bojun-Vvibe)",
  "type": "module",
  "main": "dist/cli.cjs",
  "bin": {
    "harness": "dist/cli.cjs",
    "harness-kit": "dist/cli.cjs"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "README.zh.md",
    "README.ja.md",
    "README.ko.md",
    "README.es.md",
    "README.pt.md",
    "README.fr.md",
    "README.de.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "cac": "^6.7.14",
    "fast-glob": "^3.3.2",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
